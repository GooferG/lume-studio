# Resend (transactional email)
RESEND_API_KEY=
RESEND_FROM_EMAIL=hello@yourdomain.com
RESEND_TO_EMAIL=you@yourdomain.com

# Cal.com username (booking embed). Public; safe to commit if needed.
NEXT_PUBLIC_CAL_COM_USERNAME=

# Site URL (used in metadata and sitemap)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

